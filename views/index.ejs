<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:           #0a2240;
      --teal:           #0e7c6b;
      --teal-light:     #e4f5f2;
      --teal-accent:    #7ab3cc;
      --ice:            #f0f6fc;
      --border:         #d6e4ef;
      --muted:          #6b8299;
      --text:           #0d1f2d;
      --white:          #ffffff;
      --red-light:      #fde8e8;
      --red-dark:       #b91c1c;
      --purple-light:   #f8f4ff;
      --purple:         #7c5cbf;
      --purple-dark:    #3a2a60;
      --gold-light:     #fffbf0;
      --gold:           #e8c34a;
      --gold-dark:      #b08920;
      --gold-text:      #5a4a1a;
    }
    @page {
      size: A4 !important;
      margin: 0;
    }

    @media print {
      body {
        margin: 0;
        padding: 0;
        background: white;
      }
      .page {
        width: 100%;
        min-height: 100vh;
        box-shadow: none;
      }
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--white);
      color: var(--text);
      font-size: 13px;
      line-height: 1.6;
      display: flex;
      justify-content: center;
      align-items: center;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

.page {
  width: 565px;
  min-height: 750px; 
  background: var(--white);
}

    .header {
      background: var(--navy);
      padding: 32px 44px 24px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }

    .brand-row {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }

    .brand-name {
      font-family: 'Playfair Display', serif;
      font-size: 17px;
      color: var(--white);
    }

    .brand-sub {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: var(--teal-accent);
    }

    .invoice-label h1 {
      font-family: 'Playfair Display', serif;
      font-size: 34px;
      color: var(--white);
      letter-spacing: 3px;
      text-transform: uppercase;
      line-height: 1;
      text-align: right;
    }

    .inv-number {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 1.5px;
      color: var(--teal-accent);
      margin-top: 5px;
      text-transform: uppercase;
      text-align: right;
    }

    .stripe { background: var(--teal); height: 4px; }

    .meta-row {
      background: var(--ice);
      padding: 14px 44px;
      display: flex;
      gap: 36px;
      border-bottom: 1px solid var(--border);
    }

    .meta-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 3px;
    }

    .meta-value {
      font-size: 12px;
      font-weight: 600;
      color: var(--navy);
    }

    .body {
       padding: 28px 20px;
       }

    .parties {
      display: flex;
      justify-content: space-between;
      gap: 24px;
      margin-bottom: 22px;
      padding-bottom: 22px;
      border-bottom: 1px solid var(--border);
    }

    .pill {
      display: inline-block;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--teal);
      background: var(--teal-light);
      padding: 3px 10px;
      border-radius: 20px;
      margin-bottom: 9px;
    }

    .party-name {
      font-size: 14px;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 4px;
    }

    .party-detail {
      font-size: 11px;
      color: var(--muted);
      line-height: 1.8;
    }

    /* ── CLINICAL STRIP ── */
    .clinical-strip {
      background: var(--ice);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 12px 16px;
      margin-bottom: 22px;
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      gap: 12px;
    }

    .ci-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1.8px;
      text-transform: uppercase;
      color: var(--muted);
      margin-bottom: 3px;
    }

    .ci-value {
      font-size: 12px;
      font-weight: 600;
      color: var(--navy);
    }

    .badge {
      display: inline-block;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      padding: 2px 8px;
      border-radius: 4px;
    }

    .badge-yes { background: var(--red-light); color: var(--red-dark); }
    .badge-no  { background: var(--teal-light); color: var(--teal); }

    /* ── TABLE ── */
    .items-table { width: 100%; border-collapse: collapse; }

    .items-table thead tr { background: var(--navy); }

    .items-table thead th {
      padding: 10px 12px;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--teal-accent);
      text-align: left;
    }

    .items-table thead th.r { text-align: right; }

    /* Table column widths */
    .items-table th:nth-child(1),
    .items-table td:nth-child(1) { width: 52%; }
    .items-table th:nth-child(2),
    .items-table td:nth-child(2) { width: 14%; }
    .items-table th:nth-child(3),
    .items-table td:nth-child(3) { width: 14%; }
    .items-table th:nth-child(4),
    .items-table td:nth-child(4) { width: 20%; }

    .items-table tbody tr { border-bottom: 1px solid var(--border); }
    .items-table tbody tr:last-child { border-bottom: none; }
    .items-table tbody tr:nth-child(even) { background: var(--ice); }

    .items-table tbody td {
      padding: 11px 12px;
      font-size: 12px;
      color: var(--text);
      vertical-align: top;
    }

    .items-table tbody td.r {
      text-align: right;
      font-weight: 600;
      color: var(--navy);
    }

    .code-badge {
      display: inline-block;
      background: var(--teal-light);
      color: var(--teal);
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 1px;
      padding: 1px 7px;
      border-radius: 4px;
      margin-bottom: 3px;
    }

    .empty-row td {
      text-align: center;
      color: var(--muted);
      font-size: 12px;
      padding: 24px 0;
    }

    /* ── TOTALS ── */
    .totals-wrap { display: flex; justify-content: flex-end; margin-top: 16px; }

    .totals-card {
      width: 234px;
      background: var(--ice);
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
    }

    .t-row {
      display: flex;
      justify-content: space-between;
      padding: 9px 16px;
      font-size: 12px;
      border-bottom: 1px solid var(--border);
    }

    .t-row:last-child { border-bottom: none; }
    .t-row .tl { color: var(--muted); font-weight: 500; }
    .t-row .tv { font-weight: 600; color: var(--navy); }
    .t-row.grand { background: var(--navy); }
    .t-row.grand .tl,
    .t-row.grand .tv { color: var(--white); font-weight: 700; font-size: 13px; }

    /* ── FOOTER BAND ── */
    .footer-band {
      margin-top: 24px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      border: 1px solid var(--border);
      border-radius: 8px;
      overflow: hidden;
    }

    .fp { padding: 16px 20px; }
    .fp:first-child { border-right: 1px solid var(--border); }

    .fp-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--teal);
      margin-bottom: 8px;
    }

    .fp p { font-size: 11px; color: var(--text); line-height: 1.8; }
    .fp p span { color: var(--muted); }

    /* ── DIAGNOSIS ── */
    .diagnosis-box {
      margin-top: 20px;
      background: var(--purple-light);
      border-left: 3px solid var(--purple);
      border-radius: 0 6px 6px 0;
      padding: 12px 16px;
    }

    .diagnosis-box .dlabel {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--purple);
      margin-bottom: 4px;
    }

    .diagnosis-box p { font-size: 11.5px; color: var(--purple-dark); line-height: 1.6; }

    /* ── NOTES ── */
    .notes-box {
      margin-top: 14px;
      background: var(--gold-light);
      border-left: 3px solid var(--gold);
      border-radius: 0 6px 6px 0;
      padding: 12px 16px;
    }

    .notes-box .nlabel {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--gold-dark);
      margin-bottom: 4px;
    }

    .notes-box p { font-size: 11.5px; color: var(--gold-text); line-height: 1.6; }

    /* ── PAGE FOOTER ── */
    .page-footer {
      margin-top: 24px;
      padding-top: 14px;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .page-footer p { font-size: 10px; color: var(--muted); }

    .dot {
      display: inline-block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--teal);
      margin-right: 6px;
      vertical-align: middle;
    }

    /* Status indicator */
    .status-teal { color: var(--teal); }

    /* Party alignment */
    .party-right { text-align: right; }

    /* Highlight color for totals */
    .highlight-teal { color: var(--teal); }

    /* SVG color helper */
    .svg-teal { fill: var(--teal); }
  </style>
</head>
<body>
<div class="page">

  <%
    const d = content.data;

    function fmt(val) {
      const n = parseFloat(val);
      if (isNaN(n)) return '$0.00';
      return '$' + n.toFixed(2);
    }

    function fmtDate(val) {
      if (!val || val === 'N/A') return 'N/A';
      const date = new Date(val);
      if (isNaN(date.getTime())) return val;
      return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    }

    const invoiceNo  = d.bill_id   || d.visit_id || d.id || '—';
    const apptDate   = fmtDate(d.appointment_date);
    const dueDateFmt = fmtDate(d.dueDate);
    const procedures = Array.isArray(d.procedureCodes) ? d.procedureCodes : [];
    const gross      = parseFloat(d.grossCharges)    || 0;
    const ins        = parseFloat(d.insuranceCredit) || 0;
    const adj        = parseFloat(d.adjustments)     || 0;
    const tax        = parseFloat(d.taxAndSurcharges) || 0;
    const total      = d.totalPatientDue != null
                         ? parseFloat(d.totalPatientDue)
                         : (gross - ins - adj + tax);
  %>

  <!-- HEADER -->
  <div class="header">
    <div>
      <div class="brand-row">
        <svg width="24" height="24" viewBox="0 0 28 28" fill="none">
          <rect x="10" y="0" width="8" height="28" rx="2" class="svg-teal"/>
          <rect x="0" y="10" width="28" height="8" rx="2" class="svg-teal"/>
        </svg>
        <span class="brand-name">MediCare Billing</span>
      </div>
      <div class="brand-sub">Healthcare Billing Services</div>
    </div>
    <div class="invoice-label">
      <h1>Invoice</h1>
      <div class="inv-number"># INV-<%= invoiceNo %></div>
    </div>
  </div>

  <div class="stripe"></div>


  <div class="meta-row">
    <div>
      <div class="meta-label">Appointment Date</div>
      <div class="meta-value"><%= apptDate %></div>
    </div>
    <div>
      <div class="meta-label">Due Date</div>
      <div class="meta-value"><%= dueDateFmt %></div>
    </div>
    <div>
      <div class="meta-label">Visit ID</div>
      <div class="meta-value">#<%= d.visit_id || '—' %></div>
    </div>
    <div>
      <div class="meta-label">Status</div>
      <div class="meta-value status-teal">&#9679;&nbsp;Due</div>
    </div>
  </div>

  <div class="body">

    <div class="parties">
      <div>
        <div class="pill">Patient</div>
        <div class="party-name"><%= d.patient_name || '—' %></div>
        <div class="party-detail">
          Case Type:&nbsp;<%= d.case_type || '—' %><br/>
          Category:&nbsp;<%= d.case_category || '—' %>
        </div>
      </div>
      <div class="party-right">
        <div class="pill">Attending Physician</div>
        <div class="party-name">Dr. <%= d.doctor_name || '—' %></div>
        <div class="party-detail">
          Appt:&nbsp;<%= apptDate %><br/>
          Time:&nbsp;<%= d.appointment_time || '—' %>
        </div>
      </div>
    </div>

    <div class="clinical-strip">
      <div>
        <div class="ci-label">Case Type</div>
        <div class="ci-value"><%= d.case_type || '—' %></div>
      </div>
      <div>
        <div class="ci-label">Specialty</div>
        <div class="ci-value"><%= d.case_category || '—' %></div>
      </div>
      <div>
        <div class="ci-label">Accident Related</div>
        <div class="ci-value">
          <% if (parseInt(d.is_accident) === 1) { %>
            <span class="badge badge-yes">Yes</span>
          <% } else { %>
            <span class="badge badge-no">No</span>
          <% } %>
        </div>
      </div>
    </div>

    <table class="items-table">
      <thead>
        <tr>
          <th>Description / Procedure</th>
          <th>Code</th>
          <th>Qty</th>
          <th class="r">Amount</th>
        </tr>
      </thead>
      <tbody>
        <% if (procedures.length > 0) { %>
          <% procedures.forEach(function(item) { %>
            <tr>
              <td><%= item.description || '—' %></td>
              <td>
                <% if (item.code) { %>
                  <span class="code-badge"><%= item.code %></span>
                <% } else { %>—<% } %>
              </td>
              <td><%= item.qty != null ? item.qty : (item.quantity != null ? item.quantity : 1) %></td>
              <td class="r"><%= fmt(item.price != null ? item.price : (item.amount != null ? item.amount : item.total)) %></td>
            </tr>
          <% }); %>
        <% } else { %>
          <tr class="empty-row">
            <td colspan="4">No procedure codes recorded for this visit.</td>
          </tr>
        <% } %>
      </tbody>
    </table>

    <div class="totals-wrap">
      <div class="totals-card">
        <div class="t-row">
          <span class="tl">Gross Charges</span>
          <span class="tv"><%= fmt(d.grossCharges) %></span>
        </div>
        <% if (ins > 0) { %>
        <div class="t-row">
          <span class="tl">Insurance Credit</span>
          <span class="tv highlight-teal">- <%= fmt(d.insuranceCredit) %></span>
        </div>
        <% } %>
        <% if (adj > 0) { %>
        <div class="t-row">
          <span class="tl">Adjustments</span>
          <span class="tv highlight-teal">- <%= fmt(d.adjustments) %></span>
        </div>
        <% } %>
        <div class="t-row">
          <span class="tl">Tax &amp; Surcharges</span>
          <span class="tv"><%= fmt(d.taxAndSurcharges) %></span>
        </div>
        <div class="t-row grand">
          <span class="tl">Total Patient Due</span>
          <span class="tv"><%= fmt(total) %></span>
        </div>
      </div>
    </div>

    <% if (d.diagnosis && d.diagnosis.trim() !== '') { %>
    <div class="diagnosis-box">
      <div class="dlabel">&#10010;&nbsp; Clinical Diagnosis</div>
      <p><%= d.diagnosis %></p>
    </div>
    <% } %>

    <% if (d.notes && d.notes.trim() !== '') { %>
    <div class="notes-box">
      <div class="nlabel">&#9432;&nbsp; Notes</div>
      <p><%= d.notes %></p>
    </div>
    <% } %>

    <div class="footer-band">
      <div class="fp">
        <div class="fp-label">Payment Information</div>
        <p>
          Please remit payment by&nbsp;<strong><%= dueDateFmt %></strong>.<br/>
          Reference <strong>#INV-<%= invoiceNo %></strong> when paying.
        </p>
      </div>
      <div class="fp">
        <div class="fp-label">Thank You</div>
        <p>Your health and wellbeing is our priority. For billing enquiries, contact our support team.</p>
      </div>
    </div>

    <div class="page-footer">
      <p><span class="dot"></span>MediCare Billing &mdash; Confidential Medical Document</p>
      <p>Generated <%= new Date().toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) %></p>
    </div>

  </div>
</div>
</body>
</html>
