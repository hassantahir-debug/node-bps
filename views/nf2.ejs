<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
<div class="page">

  <!-- HEADER -->
  <div class="bg-[#0a2240] text-white p-5 rounded-t-lg">
    <div class="flex justify-between items-center">
      <div>
        <h1 class="text-xl font-bold">NF-2 NO FAULT ACCIDENT FORM</h1>
        <p class="text-xs opacity-80">Healthcare & Insurance Documentation</p>
      </div>

      <div class="text-right">
        <p class="text-xs">Form ID</p>
        <p class="font-bold">
          NF2-<%= pdfData.visit_id || pdfData.bill_id || 'N/A' %>
        </p>
      </div>
    </div>
  </div>

  <div class="h-1 bg-green-600"></div>

  <div class="grid grid-cols-2 gap-4 p-4 border">

    <div>
      <p class="text-gray-500 text-xs">Patient Name</p>
      <p class="font-semibold"><%= pdfData.patient_name %></p>
    </div>

    <div>
      <p class="text-gray-500 text-xs">Doctor</p>
      <p class="font-semibold">Dr. <%= pdfData.doctor_name %></p>
    </div>

    <div>
      <p class="text-gray-500 text-xs">Visit ID</p>
      <p class="font-semibold"><%= pdfData.visit_id %></p>
    </div>

    <div>
      <p class="text-gray-500 text-xs">Date of Visit</p>
      <p class="font-semibold"><%= pdfData.appointment_date %></p>
    </div>

  </div>

  <div class="mt-3 p-4 border rounded bg-gray-50">

    <h2 class="font-bold text-sm text-[#0a2240] mb-2">
      Accident Details
    </h2>

    <div class="grid grid-cols-2 gap-3 text-sm">

      <div>
        <p class="text-gray-500 text-xs">Date of Accident</p>
        <p><%= pdfData.accident.date_of_accident %></p>
      </div>

      <div>
        <p class="text-gray-500 text-xs">Time of Accident</p>
        <p><%= pdfData.accident.time_of_accident %></p>
      </div>

      <div>
        <p class="text-gray-500 text-xs">Place</p>
        <p><%= pdfData.accident.place_of_accident %></p>
      </div>

      <div>
        <p class="text-gray-500 text-xs">Vehicle</p>
        <p>
          <%= pdfData.accident.veichle_type %>
          ( <%= pdfData.accident.veichle_model %> )
        </p>
      </div>

      <div>
        <p class="text-gray-500 text-xs">Vehicle No</p>
        <p><%= pdfData.accident.veichle_no %></p>
      </div>

      <div>
        <p class="text-gray-500 text-xs">Insurance</p>
        <p><%= pdfData.accident.insurance_names %></p>
      </div>

    </div>

  </div>

  <div class="mt-3 p-4 border rounded">

    <h2 class="font-bold text-sm text-[#0a2240]">Accident Description</h2>
    <p class="text-sm text-gray-700 mt-1">
      <%= pdfData.accident.accident_description %>
    </p>

  </div>

  <div class="mt-3 p-4 border-l-4 border-red-500 bg-red-50">

    <h2 class="font-bold text-sm text-red-600">Injury Description</h2>
    <p class="text-sm text-gray-700 mt-1">
      <%= pdfData.accident.injury_description %>
    </p>

  </div>

  <div class="mt-3 p-4 border rounded bg-gray-50">

    <h2 class="font-bold text-sm">Insurance Details</h2>

    <p class="text-sm">
      Policy No:
      <span class="font-semibold">
        <%= pdfData.accident.insurance_policy_no %>
      </span>
    </p>

  </div>

  <div class="mt-4 text-center text-xs text-gray-500">
    This NF-2 form is system generated for healthcare insurance processing.
  </div>

</div>

</body>
</html>